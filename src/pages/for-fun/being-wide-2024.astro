---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { beingWide } from "../../content/beingWide";
---

<BaseLayout
  title={beingWide.heading}
  description="A little video about Wide Tim and why he wants to be wide."
>
  <h1>{beingWide.heading}</h1>
  {beingWide.intro && <p>{beingWide.intro}</p>}

  {
    beingWide.videoEmbedUrl ? (
      beingWide.videoProvider === "youtube" ? (
        <div class="video-frame">
          <iframe
            src={beingWide.videoEmbedUrl}
            title={beingWide.heading}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      ) : beingWide.videoProvider === "instagram" ? (
        <p>
          <a href={beingWide.videoEmbedUrl} target="_blank" rel="noopener noreferrer">
            Watch on Instagram →
          </a>
        </p>
      ) : (
        <p>
          <a href={beingWide.videoEmbedUrl} target="_blank" rel="noopener noreferrer">
            Watch video →
          </a>
        </p>
      )
    ) : (
      <div class="video-placeholder">
        Video placeholder — set <code>videoEmbedUrl</code> in{" "}
        <code>src/content/beingWide.ts</code>.
      </div>
    )
  }
</BaseLayout>

<style>
  .video-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    margin-top: 1.5rem;
  }
  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 6px;
  }
  .video-placeholder {
    margin-top: 1.5rem;
    padding: 2rem;
    border: 1px dashed var(--border);
    border-radius: 6px;
    background: var(--bg-elev);
    color: var(--fg-muted);
    font-style: italic;
  }
  code {
    background: #000;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    color: var(--fg);
    font-size: 0.9em;
    font-style: normal;
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { press } from "../../content/press";

// Shared accent palette — same six colors used on home, projects, contact,
// and for-fun pages.
const palette = [
  "#f08066",
  "#4dbeb0",
  "#e8b441",
  "#a896d8",
  "#5fb3e0",
  "#ec84a3",
];

// Render newest-first. Entries without a date sink to the bottom so
// the dated history stays clean. Sorting happens here (not in press.ts)
// so the data file can be edited in any order.
const sortedPress = [...press].sort((a, b) => {
  if (!a.date && !b.date) return 0;
  if (!a.date) return 1;
  if (!b.date) return -1;
  return b.date.localeCompare(a.date);
});
---

<BaseLayout title="Wide Tim in the Press">
  <h1>Wide Tim in the Press</h1>

  {
    sortedPress.length === 0 ? (
      <p class="muted">
        No press mentions yet. Add entries in{" "}
        <code>src/content/press.ts</code>.
      </p>
    ) : (
      <ul class="press-grid">
        {sortedPress.map((p, i) => {
          const accent = palette[i % palette.length];
          const Tag = p.url ? "a" : "article";
          return (
            <li>
              <Tag
                class={`press-card${p.url ? " press-card-link" : ""}`}
                href={p.url}
                target={p.url ? "_blank" : undefined}
                rel={p.url ? "noopener noreferrer" : undefined}
                style={`--card-accent: ${accent}`}
              >
                <div class="press-meta-top">
                  <span class="press-source">{p.source}</span>
                  {p.date && <span class="press-date">{p.date}</span>}
                </div>
                <h3 class="press-title">{p.title}</h3>
                {p.excerpt && <p class="press-excerpt">{p.excerpt}</p>}
              </Tag>
            </li>
          );
        })}
      </ul>
    )
  }
</BaseLayout>

<style>
  code {
    background: var(--bg-elev);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-size: 0.85em;
  }

  .press-grid {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .press-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    text-decoration: none;
    color: var(--fg);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.1rem 1.1rem 1.25rem;
    overflow: hidden;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .press-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--card-accent, var(--border));
  }
  .press-card-link:hover {
    border-color: var(--card-accent, var(--fg));
    background: var(--bg-hover);
    color: var(--fg);
  }
  .press-card-link:hover .press-title {
    color: var(--card-accent, var(--fg));
  }

  .press-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.15rem;
  }
  .press-source {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    color: var(--card-accent, var(--fg-muted));
  }
  .press-date {
    color: var(--fg-muted);
    font-size: 0.85rem;
  }

  .press-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.3;
    letter-spacing: 0.01em;
    margin: 0.15rem 0 0;
    transition: color 0.15s ease;
  }

  .press-excerpt {
    margin: 0.5rem 0 0;
    font-size: 0.95rem;
    color: var(--fg-muted);
    font-style: italic;
    line-height: 1.55;
  }

  @media (max-width: 600px) {
    .press-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>

---
import { nav, site } from "../content/site";

const pathname = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="brand" href="/">{site.title}</a>
    <div class="nav-right">
    <nav class="site-nav" aria-label="Primary">
      <ul class="nav-list">
        {
          nav.map((item) => (
            <li class={`nav-item ${item.children ? "has-children" : ""}`}>
              <a
                href={item.href}
                class={isActive(item.href) ? "active" : ""}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noopener noreferrer" : undefined}
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="submenu">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class={isActive(child.href) ? "active" : ""}
                        target={child.external ? "_blank" : undefined}
                        rel={child.external ? "noopener noreferrer" : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <button
      id="theme-toggle"
      type="button"
      class="theme-toggle"
      aria-label="Cycle color theme"
      title="Theme"
    >
      <svg
        class="icon icon-auto"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 8a2.83 2.83 0 0 1 4 4"></path>
        <path d="M12 2v2"></path>
        <path d="M12 20v2"></path>
        <path d="m4.9 4.9 1.4 1.4"></path>
        <path d="m17.7 17.7 1.4 1.4"></path>
        <path d="M2 12h2"></path>
        <path d="M20 12h2"></path>
        <path d="m6.3 17.7-1.4 1.4"></path>
        <path d="m19.1 4.9-1.4 1.4"></path>
        <path d="M22 22 2 2"></path>
      </svg>
      <svg
        class="icon icon-light"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path>
        <path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path>
        <path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path>
        <path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path>
        <path d="m19.07 4.93-1.41 1.41"></path>
      </svg>
      <svg
        class="icon icon-dark"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
    </div>
  </div>
</header>

<script>
  // Theme controller: Auto (follows OS preference) | Light | Dark.
  // Cycles on click. Manual choice overrides.
  const CHOICE_KEY = "themeChoice";

  const TITLES = {
    auto: "Theme: Auto (follows your system). Click for Light.",
    light: "Theme: Light. Click for Dark.",
    dark: "Theme: Dark. Click for Auto.",
  };

  const osLight = window.matchMedia("(prefers-color-scheme: light)");

  function getChoice() {
    try {
      return localStorage.getItem(CHOICE_KEY) || "auto";
    } catch {
      return "auto";
    }
  }

  function setChoice(choice) {
    try {
      if (choice === "auto") localStorage.removeItem(CHOICE_KEY);
      else localStorage.setItem(CHOICE_KEY, choice);
    } catch {}
    document.documentElement.dataset.themeChoice = choice;
    const btn = document.getElementById("theme-toggle");
    if (btn) btn.title = TITLES[choice];
  }

  function applyTheme(theme) {
    document.documentElement.dataset.theme = theme;
  }

  function applyAuto() {
    applyTheme(osLight.matches ? "light" : "dark");
  }

  // Follow OS preference changes live while in auto mode.
  osLight.addEventListener("change", () => {
    if (getChoice() === "auto") applyAuto();
  });

  function init() {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.title = TITLES[getChoice()];

    // Clean up caches left behind by the old sunrise/sunset auto mode.
    try {
      localStorage.removeItem("sunCache");
      localStorage.removeItem("locCache");
    } catch {}

    btn.addEventListener("click", () => {
      const current = getChoice();
      const next =
        current === "auto" ? "light" : current === "light" ? "dark" : "auto";
      setChoice(next);
      if (next === "auto") applyAuto();
      else applyTheme(next);
    });

    if (getChoice() === "auto") applyAuto();
  }

  init();
</script>

<style>
  .site-header {
    /* Full-width container so the background bar spans the viewport.
       Inner content is centered to --container width below. */
    border-bottom: 1px solid var(--border);
    width: 100%;
  }
  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem 1.5rem;
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--fg);
  }

  .site-nav {
    display: flex;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .nav-item {
    position: relative;
  }

  .nav-item > a {
    text-decoration: none;
    color: var(--fg);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
  }
  .nav-item > a:hover,
  .nav-item > a.active {
    border-bottom-color: var(--fg);
    color: var(--fg);
  }

  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.5rem 0;
    list-style: none;
    margin: 0.5rem 0 0;
    min-width: 220px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
    z-index: 20;
  }

  .nav-item.has-children:hover .submenu,
  .nav-item.has-children:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .submenu li a {
    display: block;
    padding: 0.5rem 1rem;
    text-decoration: none;
    color: var(--fg);
    font-size: 0.9rem;
  }
  .submenu li a:hover,
  .submenu li a.active {
    background: var(--bg-hover);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .theme-toggle:hover {
    border-color: var(--fg);
    background: var(--bg-hover);
    color: var(--link-hover);
  }
  .theme-toggle .icon {
    display: none;
  }
  :root[data-theme-choice="auto"] .theme-toggle .icon-auto,
  :root[data-theme-choice="light"] .theme-toggle .icon-light,
  :root[data-theme-choice="dark"] .theme-toggle .icon-dark {
    display: block;
  }
  /* Fallback if data-theme-choice hasn't been set yet (no JS / first paint
     before the inline script writes the attribute). */
  :root:not([data-theme-choice]) .theme-toggle .icon-auto {
    display: block;
  }

  @media (max-width: 720px) {
    .site-header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .nav-right {
      width: 100%;
      justify-content: space-between;
    }
    .nav-list {
      gap: 0.75rem 1rem;
    }
    /* On small screens, show submenu items inline below the parent */
    .submenu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      border: 0;
      background: transparent;
      padding: 0 0 0 1rem;
      min-width: 0;
      margin: 0.25rem 0 0;
    }
    .submenu li a {
      padding: 0.2rem 0;
      font-size: 0.85rem;
      color: var(--fg-muted);
    }
  }
</style>

---
// 4-up (responsive) strip of recent Instagram posts, image-only.
// Each tile is IG's own embed iframe cropped via CSS so the header
// (avatar/username) and footer (caption/buttons) are hidden — only the
// post image is visible. Clicking the tile opens the post on instagram.com.
//
// Posts are curated in src/content/latestPosts.ts. Empty list shows a
// "Follow on IG" CTA in the slot's place.
import { latestPosts } from "../content/latestPosts";
import { socials } from "../content/socials";

function shortcodeFromUrl(url: string): string | null {
  const m = url.match(/instagram\.com\/(?:p|reel|tv)\/([A-Za-z0-9_-]+)/);
  return m ? m[1] : null;
}

type IgPost = { url: string; shortcode: string };
const posts: IgPost[] = [];
for (const u of latestPosts) {
  const sc = shortcodeFromUrl(u);
  if (sc) posts.push({ url: u, shortcode: sc });
}

// Build tile markup as a string and inject via set:html below. Avoids
// Astro JSX's quirk where the map callback's parameter sometimes fails
// to scope into the returned JSX expression at compile time.
const tilesHtml = posts
  .map(
    (p) =>
      `<a class="ig-thumb" href="${p.url}" target="_blank" rel="noopener noreferrer" aria-label="View on Instagram">` +
      `<iframe src="https://www.instagram.com/p/${p.shortcode}/embed/" loading="lazy" scrolling="no" tabindex="-1" allow="encrypted-media"></iframe>` +
      `</a>`,
  )
  .join("");

const igUrl =
  socials.find((s) => s.platform === "Instagram")?.url ??
  "https://www.instagram.com/wide_tim";
const igHandle =
  socials.find((s) => s.platform === "Instagram")?.handle ?? "@wide_tim";
const hasPosts = posts.length > 0;
---

<section class="latest-posts">
  <h2 class="latest-posts-title">Latest from Instagram</h2>

  {
    hasPosts ? (
      <div class="ig-carousel">
        <button
          class="ig-nav ig-prev"
          type="button"
          aria-label="Previous posts"
          data-ig-prev
        >
          ‹
        </button>

        <div class="ig-strip" data-ig-strip="" set:html={tilesHtml} />

        <button
          class="ig-nav ig-next"
          type="button"
          aria-label="Next posts"
          data-ig-next
        >
          ›
        </button>
      </div>
    ) : (
      <a class="ig-empty" href={igUrl} target="_blank" rel="noopener noreferrer">
        <span class="ig-empty-headline">No posts pinned yet</span>
        <span class="ig-empty-cta">
          Follow {igHandle} on Instagram →
        </span>
        <span class="ig-empty-hint">
          (To pin posts here, paste URLs into{" "}
          <code>src/content/latestPosts.ts</code>.)
        </span>
      </a>
    )
  }
</section>

<script is:inline>
  // Prev/next arrows scroll the strip by one tile width (+ gap) so each
  // click advances the view by exactly one post. Native scroll-snap then
  // settles on the nearest tile boundary.
  (function () {
    var strip = document.querySelector("[data-ig-strip]");
    var prev = document.querySelector("[data-ig-prev]");
    var next = document.querySelector("[data-ig-next]");
    if (!strip || !prev || !next) return;
    function step() {
      var tile = strip.querySelector(".ig-thumb");
      if (!tile) return 0;
      var rect = tile.getBoundingClientRect();
      var gap = parseFloat(window.getComputedStyle(strip).columnGap) || 0;
      return rect.width + gap;
    }
    prev.addEventListener("click", function () {
      strip.scrollBy({ left: -step(), behavior: "smooth" });
    });
    next.addEventListener("click", function () {
      strip.scrollBy({ left: step(), behavior: "smooth" });
    });
  })();
</script>

<style>
  .latest-posts {
    margin-top: 3rem;
    padding-bottom: 3rem;
  }
  .latest-posts-title {
    font-family: "Rubik Mono One", "Oswald", system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  /* Carousel: prev/next arrows + horizontally scrolling strip. The strip
     always shows N tiles per view (4 desktop, 3 tablet, 2 mobile); extra
     posts scroll horizontally rather than wrapping to a second row. */
  .ig-carousel {
    position: relative;
    /* Leave room outside the strip for the prev/next buttons on desktop. */
    padding: 0 3rem;
  }
  /* --visible controls how many tiles fit in one view. Each tile's flex
     basis is calc((100% - gap*(visible-1)) / visible) so they pack
     tightly with the gap accounted for. */
  .ig-strip {
    --visible: 4;
    --gap: 0.75rem;
    display: flex;
    gap: var(--gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 0;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }
  /* Tiles are injected via set:html on .ig-strip, so they don't get
     Astro's data-cid attribute. The rules below use :global() so the
     un-scoped tile elements still receive the styles. */
  .ig-strip :global(.ig-thumb) {
    position: relative;
    flex: 0 0 calc((100% - var(--gap) * (var(--visible) - 1)) / var(--visible));
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 6px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    text-decoration: none;
    scroll-snap-align: start;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .ig-strip :global(.ig-thumb:hover) {
    border-color: var(--fg);
    transform: translateY(-2px);
  }
  /* IG's embed iframe contains a ~54px header (avatar + username) and a
     ~120px footer (caption preview + buttons). Push the iframe up to
     hide the header, and oversize the height so the image fills the
     square while the footer falls below the overflow clip. */
  .ig-strip :global(.ig-thumb iframe) {
    position: absolute;
    top: -54px;
    left: 0;
    width: 100%;
    height: calc(100% + 54px + 220px);
    border: 0;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .ig-strip {
      --visible: 3;
    }
  }
  @media (max-width: 600px) {
    .ig-carousel {
      padding: 0;
    }
    .ig-strip {
      --visible: 2;
    }
    .ig-nav {
      display: none;
    }
  }

  /* Prev/next buttons positioned outside the strip on desktop. */
  .ig-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--fg);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .ig-nav:hover {
    border-color: var(--fg);
    background: var(--bg-hover);
  }
  .ig-prev {
    left: 0;
  }
  .ig-next {
    right: 0;
  }

  /* Empty state: shown when latestPosts is empty. */
  .ig-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    max-width: 540px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    background: var(--bg-elev);
    border: 1px dashed var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    text-align: center;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .ig-empty:hover {
    border-color: var(--fg);
    background: var(--bg-hover);
    color: var(--link-hover);
  }
  .ig-empty-headline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }
  .ig-empty-cta {
    font-family: "Rubik Mono One", "Oswald", system-ui, sans-serif;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .ig-empty-hint {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  .ig-empty-hint code {
    font-size: 0.8rem;
    padding: 0.1rem 0.3rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
  }
</style>
